# Configuration Airbnb
AIRBNB_EMAIL=votre.email@example.com
AIRBNB_PASSWORD=votre_mot_de_passe

# Google Authenticator (optionnel)
# Si vous avez activé la 2FA avec Google Authenticator
TOTP_SECRET=votre_secret_totp

# Mode headless
# false = voir le navigateur dans VNC (pour résoudre CAPTCHA)
# true = mode automatique sans interface graphique
HEADLESS=true

# Proxy résidentiel (optionnel, recommandé pour éviter les CAPTCHAs)
PROXY_URL=

# Fichiers de sortie
OUTPUT_CSV=output/reservations_airbnb.csv
OUTPUT_JSON=output/reservations_airbnb.json

# API Next.js pour envoyer les données
NEXTJS_API_URL=http://host.docker.internal:3000/api/airbnb/sync
NEXTJS_API_KEY=votre_cle_api_nextjs

# Supabase (base de données)
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
SUPABASE_SERVICE_ROLE_KEY=votre_service_role_key

# Intervalles de polling (en secondes)
ICAL_POLL_INTERVAL=300
TARGETED_POLL_INTERVAL=30

# Collecte des coordonnées des voyageurs (téléphone + email)
# true = Collecte automatique (plus lent : +5 sec par réservation)
# false = Pas de collecte automatique (utiliser 7_collecter_contacts.bat manuellement)
COLLECT_CONTACTS=false
