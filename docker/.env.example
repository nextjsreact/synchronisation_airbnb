# ============================================================================
# Variables d'environnement pour Docker
# ============================================================================
# Copiez ce fichier vers .env et remplissez vos valeurs

# ── Airbnb Credentials ──────────────────────────────────────────────────────
AIRBNB_EMAIL=votre@email.com
AIRBNB_PASSWORD=votre_mot_de_passe
TOTP_SECRET=votre_secret_2fa_optionnel

# ── API Next.js ─────────────────────────────────────────────────────────────
# URL de l'API (depuis Docker, utilisez host.docker.internal pour accéder à localhost)
NEXTJS_API_URL=http://host.docker.internal:3000/api/airbnb/sync
NEXTJS_API_KEY=NXxmDRrHzvb4I+SuGdZv9kGvd574bnhVctjKcz0rR1s=

# ── Configuration ───────────────────────────────────────────────────────────
HEADLESS=true
SYNC_TYPE=full

# ── Proxy résidentiel (optionnel) ───────────────────────────────────────────
# Évite les CAPTCHAs — CloakBrowser est anti-detection, pas anti-CAPTCHA
# Format : http://user:pass@host:port ou socks5://host:port
#PROXY_URL=http://user:pass@residential-proxy:port
